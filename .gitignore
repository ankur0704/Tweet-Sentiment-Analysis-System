# =============================================================================
# Tweet Sentiment Analysis System — .gitignore
# =============================================================================

# --- Python virtual environment ---
.venv/
venv/
env/
ENV/

# --- Compiled Python files ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# --- Distribution / packaging ---
build/
dist/
*.egg-info/
*.egg
.eggs/

# --- Trained model artefacts (large binary files) ---
# Uncomment the lines below if you do NOT want to commit the trained models.
# They can always be regenerated by running: python src/train.py
# models/*.pkl

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*.ipynb

# --- Environment / secrets ---
.env
.env.*
*.env

# --- macOS system files ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# --- VS Code / IDE settings ---
.vscode/
.idea/
*.swp
*.swo

# --- pytest / test cache ---
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# --- Streamlit cache & config ---
.streamlit/
